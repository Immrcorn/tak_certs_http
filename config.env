# TAK Certificate HTTP Server — offline package site config
# Sideload this whole folder (includes portable Python). No package manager.
#
# DIALECT NOTE:
#   - start.sh: this file is `source`d as shell (set -a).
#   - systemd EnvironmentFile=: non-shell KEY=value (no export, limited quoting).
# Keep every value a simple unquoted token so both paths match.

# Bind address: 0.0.0.0 = all interfaces
TAK_CERTS_HOST=0.0.0.0

# Listen port
TAK_CERTS_PORT=18200

# Served directory (relative = under this package). Stay package-local unless
# TAK_CERTS_ALLOW_EXTERNAL_DIR=1.
TAK_CERTS_DIR=certs

# Set to 1 only if TAK_CERTS_DIR intentionally points outside the package.
# Under systemd, install-service.sh can append absolute external paths to
# ReadWritePaths when this is set at install time.
# TAK_CERTS_ALLOW_EXTERNAL_DIR=0

# Optional override of the bundled portable CPython (default: auto by arch):
#   python/linux-x86_64/python/bin/python3
#   python/linux-aarch64/python/bin/python3
# TAK_CERTS_PYTHON=

# Lab only: allow system python3 if ≥3.7 (not for RHEL 8.1 stock 3.6)
# TAK_CERTS_ALLOW_SYSTEM_PYTHON=0

# Optional fixed URL for QR codes / user handouts (else auto-detect server IP):
# TAK_CERTS_PUBLIC_URL=http://10.1.2.3:18200/
